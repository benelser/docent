{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": false,
    "jsx": "react-jsx",
    "paths": {
      "@docent/kit": ["../../packages/kit/src/index.ts"],
      "@docent/core": ["../../packages/core/src/index.ts"]
    }
  },
  "include": ["src/**/*", "docent.config.ts"]
}
