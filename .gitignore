# dependencies
node_modules/
.venv/
.claude/

# build artifacts
out/
public/audio/
public/clips/
# Exception: the grammar-check fixture's 1-second placeholder clip is the
# only checked-in clip — it's what makes `docent grammar-check` work
# end-to-end on a fresh clone. Other clips live at the renderer's authoring
# time and aren't gallery-tracked.
!public/clips/grammar-check/
!public/clips/grammar-check/placeholder-clip.webm
.remotion/
.manim-cache/

# local dev work — never committed
archive/
dogfood/
reviews/
treatments/
manim/
*.log

# films/ and analysis/ are dual-purpose:
#
#   - The four gallery specs + the grammar-check test fixture are tracked.
#     The hermetic harness, the fresh-user gate, and the README all depend
#     on these existing under films/.
#   - Every OTHER film a user renders is a runtime artifact and stays local.
#
# Same shape for analysis/ — the gallery surveys are tracked as examples;
# every other survey is a runtime artifact.
films/*
!films/linear-algebra.json
!films/kubernetes-pr.json
!films/euclid-primes.json
!films/stopping-by-woods.json
!films/grammar-check.json
!films/ai-lab-race.json
!films/ai-agent-stack.json
!films/multi-region-db.json
!films/onboarding-first-30-minutes.json
!films/causal-loop-primer.json
!films/thermostat.json
!films/auth-overlap.json
!films/docent-landscape.json
!films/docent-self.json
!films/openclaw-ar.json
!films/lethal-trifecta-blog.json
!films/arxiv-2512-14806.json
!films/text-stress-diagrammatic.json
!films/text-stress-narrative.json
!films/rhetorical-primer.json
!films/sprint-b-composition-demo.json
!films/prior-art-primer.json

# Per-pack films under tests/example-docent-*/films/ stay tracked — they
# travel with the pack. Same blanket pattern: ignored except for the JSON
# files we explicitly want in the gallery.
analysis/*
!analysis/linear-algebra.md
!analysis/linear-algebra.source.md
!analysis/kubernetes-pr.md
!analysis/euclid-primes.md
!analysis/euclid-primes.source.md
!analysis/stopping-by-woods.md
!analysis/stopping-by-woods.source.md

# python
__pycache__/
*.pyc

# misc
.DS_Store
tests/report.json


# APM dogfood artifacts — the agent package's apm.yml lives in
# packages/agent/. The root apm.yml/apm.lock.yaml/apm_modules/ are created
# when we install the agent INTO this repo for dogfooding. They are not
# part of the package itself.
/apm.yml
/apm.lock.yaml
apm_modules/

# we use bun, not npm — keep the dead lockfile from coming back
package-lock.json

# Per-render entry scripts the CLI generates under .docent/tmp/.
# These are throwaway — regenerated on every `docent build`.
.docent/

# SvelteKit landing site — source is committed, build artifacts are not
landing/build/
landing/node_modules/
landing/.svelte-kit/
.npmrc.publish
.firebase/
