# dependencies
node_modules/
.venv/
.claude/

# build artifacts
out/
public/audio/
public/clips/
.remotion/
.manim-cache/

# local dev work — never committed
archive/
dogfood/
reviews/
treatments/
manim/
*.log

# films/ and analysis/ are dual-purpose:
#
#   - The four gallery specs + the grammar-check test fixture are tracked.
#     The hermetic harness, the fresh-user gate, and the README all depend
#     on these existing under films/.
#   - Every OTHER film a user renders is a runtime artifact and stays local.
#
# Same shape for analysis/ — the gallery surveys are tracked as examples;
# every other survey is a runtime artifact.
films/*
!films/linear-algebra.json
!films/kubernetes-pr.json
!films/euclid-primes.json
!films/stopping-by-woods.json
!films/grammar-check.json
!films/ai-lab-race.json
!films/ai-agent-stack.json
!films/multi-region-db.json
!films/onboarding-first-30-minutes.json
!films/causal-loop-primer.json
analysis/*
!analysis/linear-algebra.md
!analysis/linear-algebra.source.md
!analysis/kubernetes-pr.md
!analysis/euclid-primes.md
!analysis/euclid-primes.source.md
!analysis/stopping-by-woods.md
!analysis/stopping-by-woods.source.md

# python
__pycache__/
*.pyc

# misc
.DS_Store
tests/report.json


# APM dogfood artifacts — the agent package's apm.yml lives in
# packages/agent/. The root apm.yml/apm.lock.yaml/apm_modules/ are created
# when we install the agent INTO this repo for dogfooding. They are not
# part of the package itself.
/apm.yml
/apm.lock.yaml
apm_modules/

# we use bun, not npm — keep the dead lockfile from coming back
package-lock.json
