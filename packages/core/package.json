{
  "name": "@bjelser/core",
  "version": "3.0.12",
  "description": "docent's default implementation: 29 canonical scene plugins, 6 presets, the Kokoro TTS adapter, and the default narration + audio-rhythm features. Depends on @bjelser/kit; registers everything through the framework's public API.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/benelser/docent",
  "repository": {
    "type": "git",
    "url": "https://github.com/benelser/docent.git",
    "directory": "packages/core"
  },
  "exports": {
    ".": "./src/index.ts",
    "./browser": "./src/index.browser.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "gen:manifest": "bun scripts/gen-manifest.ts",
    "gen:manifest:check": "bun scripts/gen-manifest.ts && git diff --exit-code -- src/index.generated.ts"
  },
  "dependencies": {
    "@bjelser/kit": "^3.0.0",
    "kokoro-js": "^1.2.1",
    "prism-react-renderer": "^2.4.1",
    "roughjs": "^4.6.6"
  },
  "peerDependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/google-fonts": "^4.0.0",
    "@remotion/paths": "^4.0.0",
    "@remotion/shapes": "^4.0.0",
    "@remotion/transitions": "^4.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.29",
    "react": "^18.3.1",
    "remotion": "^4.0.464",
    "typescript": "^6.0.3"
  },
  "browser": {
    "node:fs": false,
    "node:path": false,
    "node:child_process": false,
    "node:os": false,
    "fs": false,
    "path": false,
    "child_process": false,
    "os": false
  }
}
