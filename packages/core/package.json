{
  "name": "@docent/core",
  "version": "3.0.0-rc.0",
  "description": "docent's default implementation: 29 canonical scene plugins, 6 presets, the Kokoro TTS adapter, and the default narration + audio-rhythm features. Depends on @docent/kit; registers everything through the framework's public API.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/benelser/docent",
  "repository": {
    "type": "git",
    "url": "https://github.com/benelser/docent.git",
    "directory": "packages/core"
  },
  "exports": {
    ".": "./src/index.ts",
    "./scenes/*": "./src/scenes/*/index.ts",
    "./presets/*": "./src/presets/*/index.ts",
    "./features/*": "./src/features/*/index.ts",
    "./tts/*": "./src/tts/*/index.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "gen:manifest": "bun scripts/gen-manifest.ts",
    "gen:manifest:check": "bun scripts/gen-manifest.ts && git diff --exit-code -- src/index.generated.ts"
  },
  "dependencies": {
    "@docent/kit": "workspace:*",
    "kokoro-js": "^1.2.1",
    "prism-react-renderer": "^2.4.1",
    "roughjs": "^4.6.6"
  },
  "peerDependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/google-fonts": "^4.0.0",
    "@remotion/paths": "^4.0.0",
    "@remotion/shapes": "^4.0.0",
    "@remotion/transitions": "^4.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.29",
    "react": "^18.3.1",
    "remotion": "^4.0.464",
    "typescript": "^6.0.3"
  }
}
