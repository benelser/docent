{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docent.dev/schema/film.schema.json",
  "title": "docent film spec",
  "description": "The contract between the agent layer (which authors a spec) and the engine (which renders it). Versioned; the engine validates every spec against the structural subset of this in cli/validate.ts.",
  "type": "object",
  "required": ["meta", "scenes"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["id", "title", "subject", "prompt", "fps", "width", "height"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
        "title": {"type": "string"},
        "subject": {"type": "string"},
        "repo": {"type": "string"},
        "prompt": {"type": "string", "description": "architecture review | pr review"},
        "fps": {"type": "number", "exclusiveMinimum": 0},
        "width": {"type": "number", "exclusiveMinimum": 0},
        "height": {"type": "number", "exclusiveMinimum": 0},
        "voice": {"type": "string"},
        "register": {"enum": ["grave", "neutral", "calm", "urgent", "playful"]}
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/scene"}
    }
  },
  "$defs": {
    "scene": {
      "type": "object",
      "required": ["id", "type", "beats"],
      "properties": {
        "id": {"type": "string"},
        "type": {"enum": ["frame", "structure", "progression", "walkthrough", "compare", "quantities", "probe", "tension", "closeup", "demonstrate", "recap", "diff", "chart"]},
        "accent": {"enum": ["blue", "cyan", "green", "amber", "rose", "violet"]},
        "kicker": {"type": "string"},
        "heading": {"type": "string"},
        "cut": {"enum": ["dissolve", "hold", "continue"]},
        "palette": {"enum": ["cool", "warm", "signal", "mono"]},
        "treatment": {"enum": ["crisp", "sketch"]},
        "metrics": {
          "type": "array",
          "description": "quantities scenes — figure cards whose number is a tweened value that counts up across beats",
          "items": {"$ref": "#/$defs/metric"}
        },
        "xAxis": {"$ref": "#/$defs/axis", "description": "chart scenes — the horizontal axis domain"},
        "yAxis": {"$ref": "#/$defs/axis", "description": "chart scenes — the vertical axis domain"},
        "series": {
          "type": "array",
          "description": "chart scenes — the plotted series (line / bars / point)",
          "items": {"$ref": "#/$defs/series"}
        },
        "beats": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/beat"}
        }
      }
    },
    "beat": {
      "type": "object",
      "required": ["id", "narration"],
      "properties": {
        "id": {"type": "string", "description": "unique across the whole film — the TTS cache keys on it"},
        "narration": {"type": "string", "minLength": 1},
        "pace": {"enum": ["hold", "settle", "normal", "brisk"]},
        "cadence": {"enum": ["cascade", "together", "snap"]},
        "shot": {"enum": ["wide", "follow", "push", "hold"]},
        "set": {
          "type": "object",
          "description": "tween directive — named values this beat drives; the engine eases each from the value the prior set-beat held",
          "additionalProperties": {
            "oneOf": [
              {"type": "number"},
              {"$ref": "#/$defs/tween"}
            ]
          }
        }
      }
    },
    "tween": {
      "type": "object",
      "description": "a value the engine interpolates across a beat boundary",
      "required": ["to"],
      "additionalProperties": false,
      "properties": {
        "to": {"type": "number", "description": "the target the beat drives toward"},
        "from": {"type": "number", "description": "explicit start value, used only by the first beat to set this key"},
        "ease": {"enum": ["linear", "spring", "accelerate", "settle"]}
      }
    },
    "metric": {
      "type": "object",
      "description": "a figure card whose displayed number IS a tweened value",
      "required": ["id", "label", "col", "row", "bind"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string"},
        "label": {"type": "string"},
        "col": {"type": "integer", "minimum": 0},
        "row": {"type": "integer", "minimum": 0},
        "bind": {"type": "string", "description": "the `set` key this metric's number reads from"},
        "format": {"enum": ["int", "float1", "percent"]},
        "unit": {"type": "string"},
        "accent": {"enum": ["blue", "cyan", "green", "amber", "rose", "violet"]}
      }
    },
    "axis": {
      "type": "object",
      "description": "a chart axis — a labelled domain the engine maps onto STAGE pixels",
      "required": ["label", "min", "max"],
      "additionalProperties": false,
      "properties": {
        "label": {"type": "string"},
        "min": {"type": "number"},
        "max": {"type": "number", "description": "must be greater than min"},
        "ticks": {"type": "integer", "minimum": 2, "maximum": 10, "description": "tick marks along the axis; capped at 10 for legibility"}
      }
    },
    "series": {
      "type": "object",
      "description": "a plotted chart series. `kind` picks the geometry; a `line` names a `fn` from the closed allowlist or gives explicit `points`, `bars` carries `data`, `point` is a marker bound to a curve.",
      "required": ["id", "kind"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string"},
        "kind": {"enum": ["line", "bars", "point"]},
        "accent": {"enum": ["blue", "cyan", "green", "amber", "rose", "violet"]},
        "fn": {
          "enum": ["linear", "x^2", "sqrt", "sin", "exp", "log", "reciprocal"],
          "description": "line series — a named function from the closed allowlist; never an arbitrary expression"
        },
        "points": {
          "type": "array",
          "description": "line series — an explicit polyline, an alternative to `fn`",
          "minItems": 2,
          "items": {
            "type": "array",
            "items": {"type": "number"},
            "minItems": 2,
            "maxItems": 2
          }
        },
        "data": {
          "type": "array",
          "description": "bars series — one datum per bar; capped at 8 for legibility",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["label", "value"],
            "additionalProperties": false,
            "properties": {
              "label": {"type": "string"},
              "value": {"type": "number"}
            }
          }
        },
        "bind": {"type": "string", "description": "point series — a `set` key giving the marker's x"},
        "along": {"type": "string", "description": "point series — the line series id whose curve gives the marker's y"}
      }
    }
  }
}
