      "footnote": "a fixture that exercises every scene type end to end",
      "beats": [
        {
          "id": "frame-1",
          "narration": "Every docent film is built from one closed grammar of explanation.",
          "show": "title"
        },
        {
          "id": "frame-2",
          "narration": "This fixture walks all of the scene types, one at a time.",
          "show": "tagline"
        }
      ]
    },
